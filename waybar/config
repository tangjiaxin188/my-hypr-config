{
    "layer": "top",
    "position": "top", 
    "height": 40, 
    "spacing": 6,
    "modules-left": ["niri/window"],
    "modules-center": ["custom/arch","niri/workspaces"],
    "modules-right": ["tray", "custom/clipboard","network", "pulseaudio","pulseaudio#microphone", "memory", "cpu","battery", "clock","custom/poweroff"],
    "wlr/workspaces": {
        "format": "{icon}",
        "sort-by-number": true,
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1"
    },
    "custom/clipboard": {
	"format":"\uf07f",
	"on-click": "/usr/bin/sh /home/tangjiaxin/showclipboard.sh",
	"on-click-right": "/usr/bin/sh /home/tangjiaxin/delclipboard.sh",
	"tooltip-format": "з‚№е‡»ж‰“ејЂпјЊеЏій”®е€ й™¤"
    },
    "custom/poweroff": {
	"format":"\uf011",
	"on-click": "nwg-bar"
    },
    "battery": {
	"format": "{capacity}% \uf240",
	"format-charging": "вљЎ {capacity}% \uf240",
	"format-warning": "вљ пёЏ {capacity}% \uf243",
    	"format-critical": "рџ”ґ {capacity}% \uf244"
    },
    "custom/arch": {
	"format": "\uf303",
	"on-click": "wofi --show drun"
    },
    "niri/window": {
        "format": "\uf061 {}",
        "separate-outputs": true
    },
    "tray": {
        "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        "interval": 1,
        "format": "\uf017 {:%H:%M:%S}",
        "format-alt": "\uf133 {:%Y-%m-%d %H:%M:%S}"
    },
    "cpu": {
        "interval": 1,
        "format": "п‹› {usage}%",
        "tooltip": false
    },
    "memory": {
        "interval": 1,
        "format": "пѓ‰ {used}G",
        "tooltip": false
    },
    "network": {
        "interval": 1,
        "format-wifi": "п‡« {essid} ({signalStrength}%)",
        "format-ethernet": "\uf796 {bandwidthUpBits} {bandwidthDownBits}",
        "format-linked": "пћ– {ifname} (No IP)",
        "format-disconnected": "вљ  Disconnected",
        "tooltip-format": "пћ– {ifname} {ipaddr}/{cidr} via {gwaddr}",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        "scroll-step": 5,
        "format": "{icon} {volume}%",
        "format-muted": "\uf466",
        "format-bluetooth": "пЉ” {volume}%",
        "format-bluetooth-muted": "\uf466 пЉ”",
        "format-icons": {
            "headphone": "пЂҐ",
            "hands-free": "п–ђ",
            "headset": "п–ђ",
            "phone": "п‚•",
            "portable": "п‚•",
            "car": "п†№",
            "default": ["пЂ¦", "пЂ§", "пЂЁ"]
        },
        "on-click-right": "pavucontrol",
	"on-click" : "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
    },
    "pulseaudio#microphone":{
    	"format":"{format_source}",
	"format-source":"\uf130 {volume}%",
	"format-source-muted": "\uf131",
    	"on-click": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
	"on-click-right": "pavucontrol",
    	"on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 5%+",
    	"on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 5%-"
    }
}
